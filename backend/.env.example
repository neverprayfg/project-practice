APP_ENV=development
STORAGE_ROOT=/workspace
EXPORT_ROOT=/exports
TESTLIB_ROOT=../testlib
JNGEN_ROOT=../jngen
STORAGE_VOLUME=contest_dataset_storage
RUNNER_COMPILE_IMAGE=contest-dataset-runner-compiler:0.3.0
RUNNER_EXECUTE_IMAGE=contest-dataset-runner-executor:0.3.0
RUNNER_MEMORY=512m
RUNNER_NANO_CPUS=1000000000
RUNNER_TIMEOUT_SECONDS=30
RUNNER_CONCURRENCY=2
RUNNER_BATCH_SIZE=16
MANIFEST_CHECKPOINT_INTERVAL=10
MAX_TOOL_CALLS_PER_RUN=4

MODEL_BASE_URL=https://api.deepseek.com/v1
MODEL_API_KEY=
MODEL_NAME=deepseek-chat
MODEL_TIMEOUT_SECONDS=300
AGENT_ALLOW_LEGACY_KEYWORD_ROUTING=false

DOCKER_HOST=tcp://docker-api:2375
